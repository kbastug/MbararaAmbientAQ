Can we adjust this to be from 2021-2024, and the weekly average instead of month?


Thought for 29s
Yes — but not with GHAP: GHAP only runs 2017–2022. 

For 2021–2024 with weekly averages, the cleanest “in-catalog” option in GEE is ECMWF/CAMS/NRT, which has daily cadence and includes PM2.5 mass concentration as particulate_matter_d_less_than_25_um_surface (units kg/m³). 

Below is a paste-ready script that:

builds a Mbarara area geometry (with a safe fallback),

pulls one daily field per day (init hour 0, forecast hour 0),

converts kg/m³ → µg/m³,

computes weekly mean PM2.5 from 2021-01-01 to 2025-01-01 (i.e., 2021–2024),

charts + exports CSV.

GEE Code Editor script: Weekly PM2.5 (CAMS NRT), 2021–2024, Mbarara
/**** Weekly PM2.5 for Mbarara (Uganda), 2021–2024
 *  Source: ECMWF/CAMS/NRT
 *  Band: particulate_matter_d_less_than_25_um_surface (kg/m^3)  :contentReference[oaicite:2]{index=2}
 *  Convert to µg/m^3: kg/m^3 * 1e9
 *
 *  IMPORTANT: CAMS NRT is coarse (~44 km pixels) and is a forecast product;
 *  we select initialization hour 0 and forecast hour 0 to get one daily field. :contentReference[oaicite:3]{index=3}
 ****/

// -------------------------------
// 1) Define region: Mbarara (GAUL level2) with robust matching + fallback
// -------------------------------
var gaul2 = ee.FeatureCollection('FAO/GAUL/2015/level2');
var ug2 = gaul2.filter(ee.Filter.eq('ADM0_NAME', 'Uganda'));

// Try to match any ADM2_NAME containing "Mbar"
var mbarCandidates = ug2.filter(ee.Filter.stringContains('ADM2_NAME', 'Mbar'));
print('GAUL ADM2 candidates containing "Mbar":', mbarCandidates.aggregate_array('ADM2_NAME'));
print('Candidate feature count:', mbarCandidates.size());

var mbarGeom = ee.FeatureCollection(mbarCandidates).geometry();

// Fallback ~20 km buffer around Mbarara town if GAUL match fails
var fallback = ee.Geometry.Point([30.65, -0.61]).buffer(20000);

var region = ee.Geometry(ee.Algorithms.If(mbarCandidates.size().gt(0), mbarGeom, fallback));

Map.centerObject(region, 10);
Map.addLayer(region, {color: 'yellow'}, 'Mbarara area (GAUL match or fallback)');

// -------------------------------
// 2) Load CAMS NRT daily PM2.5 (choose one image per day)
// -------------------------------
var start = ee.Date('2021-01-01');
var end   = ee.Date('2025-01-01'); // up through end of 2024

var cams = ee.ImageCollection('ECMWF/CAMS/NRT')
  .filterDate(start, end)
  .filter('model_initialization_hour == 0')
  .filter('model_forecast_hour == 0')
  .select('particulate_matter_d_less_than_25_um_surface');

// Convert kg/m^3 to µg/m^3 (1 kg = 1e9 µg)
var cams_pm25 = cams.map(function(img) {
  return img.multiply(1e9).rename('pm25_ugm3')
    .copyProperties(img, ['system:time_start']);
});

print('Daily CAMS PM2.5 images:', cams_pm25.size());

// Quick map of mean over period
var meanPM = cams_pm25.mean().clip(region);
Map.addLayer(meanPM, {min: 0, max: 100}, 'Mean PM2.5 (µg/m³), 2021–2024');

// -------------------------------
// 3) Weekly aggregation (7-day mean)
// -------------------------------
var nWeeks = end.difference(start, 'week').floor();
var weeks = ee.List.sequence(0, nWeeks.subtract(1));

var weeklyImages = ee.ImageCollection.fromImages(
  weeks.map(function(w) {
    w = ee.Number(w);
    var wkStart = start.advance(w, 'week');
    var wkEnd = wkStart.advance(1, 'week');
    var wkMean = cams_pm25.filterDate(wkStart, wkEnd).mean()
      .set('system:time_start', wkStart.millis())
      .set('week_start', wkStart.format('YYYY-MM-dd'))
      .set('week_end', wkEnd.advance(-1, 'day').format('YYYY-MM-dd'));
    return wkMean;
  })
);

print('Weekly images:', weeklyImages.size());

// -------------------------------
// 4) Reduce to a weekly time series over region
// -------------------------------
var weeklyTS = weeklyImages.map(function(img) {
  var stats = img.reduceRegion({
    reducer: ee.Reducer.mean(),
    geometry: region,
    scale: 45000,     // CAMS pixel size ~44,528 m :contentReference[oaicite:4]{index=4}
    maxPixels: 1e13
  });

  return ee.Feature(null, {
    week_start: img.get('week_start'),
    week_end: img.get('week_end'),
    pm25_ugm3: stats.get('pm25_ugm3')
  });
}).filter(ee.Filter.notNull(['pm25_ugm3']));

print('Weekly time series (first 10):', weeklyTS.limit(10));
print('Weekly TS rows:', weeklyTS.size());

// Chart
var chart = ui.Chart.feature.byFeature(weeklyTS, 'week_start', 'pm25_ugm3')
  .setChartType('LineChart')
  .setOptions({
    title: 'Mbarara area — Weekly mean PM2.5 (CAMS NRT), 2021–2024',
    hAxis: {title: 'Week start'},
    vAxis: {title: 'PM2.5 (µg/m³)'},
    lineWidth: 2,
    pointSize: 0
  });
print(chart);

// -------------------------------
// 5) Export weekly CSV to Google Drive
// -------------------------------
Export.table.toDrive({
  collection: weeklyTS,
  description: 'Mbarara_CAMS_NRT_Weekly_PM25_2021_2024',
  fileFormat: 'CSV'
});
