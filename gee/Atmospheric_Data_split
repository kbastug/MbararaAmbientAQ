// Weekly PM2.5 exports by year (Mbarara point), CAMS NRT
// Converts kg/m^3 -> µg/m^3 by * 1e9
// NOTE: This creates 4 export tasks (2021–2024). Run them from the Tasks tab.

var pt = ee.Geometry.Point([30.65, -0.61]);   // Mbarara town approx
var scaleMeters = 45000;                       // CAMS ~44 km grid

function weeklyTableForYear(year) {
  var yearStart = ee.Date.fromYMD(year, 1, 1);
  var yearEnd   = yearStart.advance(1, 'year');

  // Daily PM2.5 images for that year
  var camsDaily = ee.ImageCollection('ECMWF/CAMS/NRT')
    .filterDate(yearStart, yearEnd)
    .filter('model_initialization_hour == 0')
    .filter('model_forecast_hour == 0')
    .select('particulate_matter_d_less_than_25_um_surface')
    .map(function(img) {
      return img.multiply(1e9).rename('pm25_ugm3')
        .copyProperties(img, ['system:time_start']);
    });

  // Weekly windows within that year
  var nWeeks = yearEnd.difference(yearStart, 'week').floor();
  var weeks = ee.List.sequence(0, nWeeks.subtract(1));

  var weekly = ee.FeatureCollection(weeks.map(function(w) {
    w = ee.Number(w);
    var ws = yearStart.advance(w, 'week');
    var we = ws.advance(1, 'week');

    var wkMeanImg = camsDaily.filterDate(ws, we).mean();

    var pm = wkMeanImg.reduceRegion({
      reducer: ee.Reducer.mean(),
      geometry: pt,
      scale: scaleMeters,
      bestEffort: true,
      maxPixels: 1e13
    }).get('pm25_ugm3');

    // Use .set() to avoid occasional “0 columns” weirdness
    return ee.Feature(null)
      .set('week_start', ws.format('YYYY-MM-dd'))
      .set('week_end', we.advance(-1, 'day').format('YYYY-MM-dd'))
      .set('pm25_ugm3', pm)
      .set('year', year);
  })).filter(ee.Filter.notNull(['pm25_ugm3']));

  return weekly;
}

// Create and queue export tasks (run them from the Tasks tab)
[2021, 2022, 2023, 2024].forEach(function(y) {
  var tbl = weeklyTableForYear(y);

  Export.table.toDrive({
    collection: tbl,
    description: 'Mbarara_CAMS_Weekly_PM25_' + y,
    fileFormat: 'CSV'
  });
});

