/****  GHAP monthly PM2.5 (1 km) for Mbarara District, Uganda (2017–2022)
 *     Dataset: projects/sat-io/open-datasets/GHAP/GHAP_M1K_PM25
 *     Notes: GHAP PM2.5 has a documented scaling factor of 0.1 (i.e., value * 0.1 = µg/m³).  :contentReference[oaicite:2]{index=2}
 ****/

// -------------------------------
// 1) Load boundary: Mbarara District (GAUL level 2)
// -------------------------------
var gaul2 = ee.FeatureCollection('FAO/GAUL/2015/level2');
var mbarara = gaul2
  .filter(ee.Filter.eq('ADM0_NAME', 'Uganda'))
  .filter(ee.Filter.eq('ADM2_NAME', 'Mbarara'))
  .geometry();

// If the filter fails (naming occasionally differs), uncomment the fallback buffer:
// var mbarara = ee.Geometry.Point([30.65, -0.61]).buffer(20000);

Map.centerObject(mbarara, 10);
Map.addLayer(mbarara, {color: 'yellow'}, 'Mbarara (GAUL lvl2)');

// -------------------------------
// 2) Load GHAP monthly PM2.5
// -------------------------------
var ghapMonthlyRaw = ee.ImageCollection('projects/sat-io/open-datasets/GHAP/GHAP_M1K_PM25')
  .filterDate('2017-01-01', '2023-01-01');

// Debug: see what bands exist
print('GHAP monthly band names:', ghapMonthlyRaw.first().bandNames());

// Select band 0, apply scaling factor (0.1), rename to pm25_ugm3
var ghapMonthly = ghapMonthlyRaw.map(function(img) {
  return img.select([0]).multiply(0.1).rename('pm25_ugm3')
    .copyProperties(img, ['system:time_start']);
});

// -------------------------------
// 3) Map layer: mean PM2.5 over full period
// -------------------------------
var meanPM = ghapMonthly.mean().clip(mbarara);
Map.addLayer(meanPM, {min: 0, max: 50}, 'Mean PM2.5 (µg/m³), 2017–2022');

// -------------------------------
// 4) Time series: monthly mean PM2.5 over Mbarara
// -------------------------------
var ts = ghapMonthly.map(function(img) {
  var stats = img.reduceRegion({
    reducer: ee.Reducer.mean(),
    geometry: mbarara,
    scale: 1000,        // GHAP is 1 km
    maxPixels: 1e13
  });
  return ee.Feature(null, {
    date: ee.Date(img.get('system:time_start')).format('YYYY-MM-dd'),
    pm25_ugm3: stats.get('pm25_ugm3')
  });
});

print('Monthly PM2.5 time series (Mbarara):', ts.limit(10));

// Chart in-console
var chart = ui.Chart.feature.byFeature(ts, 'date', 'pm25_ugm3')
  .setChartType('LineChart')
  .setOptions({
    title: 'Mbarara District — Monthly mean PM2.5 (GHAP, 1 km)',
    hAxis: {title: 'Date'},
    vAxis: {title: 'PM2.5 (µg/m³)'},
    lineWidth: 2,
    pointSize: 0
  });
print(chart);

// -------------------------------
// 5) Export time series to Google Drive as CSV
// -------------------------------
Export.table.toDrive({
  collection: ts,
  description: 'Mbarara_GHAP_Monthly_PM25_2017_2022',
  fileFormat: 'CSV'
});
