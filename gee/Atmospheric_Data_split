        bestEffort: true,
        maxPixels: 1e13
      }).get('precipitation'),
      null
    );

    // ERA5-Land
    var eraImg = ee.ImageCollection('ECMWF/ERA5_LAND/DAILY_AGGR')
      .filterDate(date, next)
      .first();

    var tempK = ee.Algorithms.If(
      eraImg,
      ee.Image(eraImg).reduceRegion({
        reducer: ee.Reducer.mean(),
        geometry: pt,
        scale: 11000,
        bestEffort: true,
        maxPixels: 1e13
      }).get('temperature_2m'),
      null
    );

    var dewK = ee.Algorithms.If(
      eraImg,
      ee.Image(eraImg).reduceRegion({
        reducer: ee.Reducer.mean(),
        geometry: pt,
        scale: 11000,
        bestEffort: true,
        maxPixels: 1e13
      }).get('dewpoint_temperature_2m'),
      null
    );

    var tempC = ee.Algorithms.If(tempK, ee.Number(tempK).subtract(273.15), null);
    var dewC  = ee.Algorithms.If(dewK, ee.Number(dewK).subtract(273.15), null);

    var rh = ee.Algorithms.If(
      ee.Algorithms.IsEqual(tempC, null),
      null,
      ee.Number(100).multiply(
        ee.Number(
          ee.Number(17.625).multiply(ee.Number(dewC))
            .divide(ee.Number(243.04).add(ee.Number(dewC)))
            .subtract(
              ee.Number(17.625).multiply(ee.Number(tempC))
                .divide(ee.Number(243.04).add(ee.Number(tempC)))
            )
        ).exp()
      )
    );

    return ee.Feature(null, {
      date: date.format('YYYY-MM-dd'),
      pm25_ugm3: pmVal,
      rainfall_mm_day: rainVal,
      temp_c: tempC,
      dewpoint_c: dewC,
      rh_pct: rh
    });
  }));
}

