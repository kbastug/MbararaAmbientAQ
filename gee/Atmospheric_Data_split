/**** Robust GHAP monthly PM2.5 (1 km) for Mbarara area, Uganda (2017–2022) ****/

// -------------------------------
// 1) Load GAUL level2 and inspect Uganda ADM2 names
// -------------------------------
var gaul2 = ee.FeatureCollection('FAO/GAUL/2015/level2');
var ug2 = gaul2.filter(ee.Filter.eq('ADM0_NAME', 'Uganda'));

// Print all ADM2 names that contain "Mbar" (to see what GAUL calls it)
var mbarCandidates = ug2
  .filter(ee.Filter.stringContains('ADM2_NAME', 'Mbar'));

print('GAUL ADM2 candidates containing "Mbar":', mbarCandidates.aggregate_array('ADM2_NAME'));
print('Candidate feature count:', mbarCandidates.size());

// Build Mbarara geometry (union of all matches)
var mbararaGeom = ee.FeatureCollection(mbarCandidates).geometry();

// If nothing matched, fall back to a point buffer near Mbarara town
// (prevents empty geometry crash)
var fallback = ee.Geometry.Point([30.65, -0.61]).buffer(20000); // ~20 km buffer
var mbarara = ee.Algorithms.If(mbarCandidates.size().gt(0), mbararaGeom, fallback);
mbarara = ee.Geometry(mbarara);

Map.centerObject(mbarara, 10);
Map.addLayer(mbarara, {color: 'yellow'}, 'Mbarara area (GAUL match or fallback)');

// -------------------------------
// 2) Load GHAP monthly PM2.5 and auto-detect band name
// -------------------------------
var ghapMonthlyRaw = ee.ImageCollection('projects/sat-io/open-datasets/GHAP/GHAP_M1K_PM25')
  .filterDate('2017-01-01', '2023-01-01');

print('GHAP monthly first image band names:', ghapMonthlyRaw.first().bandNames());

// Auto-pick the first band name safely
var bandName = ee.String(ghapMonthlyRaw.first().bandNames().get(0));
print('Using GHAP band:', bandName);

// Apply scaling factor (0.1) per GHAP documentation and rename
var ghapMonthly = ghapMonthlyRaw.map(function(img) {
  var pm = img.select([bandName]).multiply(0.1).rename('pm25_ugm3');
  return pm.copyProperties(img, ['system:time_start']);
});

// -------------------------------
// 3) Map layer: mean PM2.5 over full period
// -------------------------------
var meanPM = ghapMonthly.mean().clip(mbarara);
Map.addLayer(meanPM, {min: 0, max: 50}, 'Mean PM2.5 (µg/m³), 2017–2022');

// -------------------------------
// 4) Time series: monthly mean PM2.5 over Mbarara
// -------------------------------
var ts = ghapMonthly.map(function(img) {
  var stats = img.reduceRegion({
    reducer: ee.Reducer.mean(),
    geometry: mbarara,
    scale: 1000,
    maxPixels: 1e13
  });

  return ee.Feature(null, {
    date: ee.Date(img.get('system:time_start')).format('YYYY-MM-dd'),
    pm25_ugm3: stats.get('pm25_ugm3')
  });
});

// Filter out months where reduceRegion returned null (fixes chart error)
ts = ts.filter(ee.Filter.notNull(['pm25_ugm3']));

print('Monthly PM2.5 time series (first 10 rows):', ts.limit(10));
print('Time series row count after notNull filter:', ts.size());

// Chart
var chart = ui.Chart.feature.byFeature(ts, 'date', 'pm25_ugm3')
  .setChartType('LineChart')
  .setOptions({
    title: 'Mbarara area — Monthly mean PM2.5 (GHAP, 1 km)',
    hAxis: {title: 'Date'},
    vAxis: {title: 'PM2.5 (µg/m³)'},
    lineWidth: 2,
    pointSize: 0
  });
print(chart);

// -------------------------------
// 5) Export time series to Google Drive as CSV
// -------------------------------
Export.table.toDrive({
  collection: ts,
  description: 'Mbarara_GHAP_Monthly_PM25_2017_2022',
  fileFormat: 'CSV'
});
