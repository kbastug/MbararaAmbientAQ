Is it easy to make a csv with the weekly average, not every 7th day?

Yes — and it’s actually simpler and more stable to compute the weekly average in Google Earth Engine and export it directly as CSV, without trying to draw charts in the Code Editor.

The key trick is to build weekly windows and reduce them to a point value, then export that small table (~209 rows).

Below is a clean script that exports weekly averages (not every 7th day) for 2021–2024.

Google Earth Engine Script: Export Weekly PM2.5 Averages (CSV)
Paste into the Code Editor and run.

// Weekly PM2.5 averages for Mbarara (point), 2021–2024
// Source: ECMWF/CAMS/NRT

var pt = ee.Geometry.Point([30.65, -0.61]);   // Mbarara town

var start = ee.Date('2021-01-01');
var end   = ee.Date('2025-01-01');

// Load daily PM2.5
var camsDaily = ee.ImageCollection('ECMWF/CAMS/NRT')
  .filterDate(start, end)
  .filter('model_initialization_hour == 0')
  .filter('model_forecast_hour == 0')
  .select('particulate_matter_d_less_than_25_um_surface')
  .map(function(img) {
    return img.multiply(1e9).rename('pm25_ugm3')
      .copyProperties(img, ['system:time_start']);
  });

// Number of weeks
var nWeeks = end.difference(start, 'week').floor();
var weeks = ee.List.sequence(0, nWeeks.subtract(1));

// Build weekly table
var weeklyTable = ee.FeatureCollection(
  weeks.map(function(w) {

    var weekStart = start.advance(w, 'week');
    var weekEnd   = weekStart.advance(1, 'week');

    var weeklyMean = camsDaily
      .filterDate(weekStart, weekEnd)
      .mean();

    var pm = weeklyMean.reduceRegion({
      reducer: ee.Reducer.mean(),
      geometry: pt,
      scale: 45000,
      bestEffort: true,
      maxPixels: 1e13
    }).get('pm25_ugm3');

    return ee.Feature(null, {
      week_start: weekStart.format('YYYY-MM-dd'),
      week_end: weekEnd.advance(-1, 'day').format('YYYY-MM-dd'),
      pm25_ugm3: pm
    });

  })
).filter(ee.Filter.notNull(['pm25_ugm3']));

print("Weekly rows:", weeklyTable.size());

// Export CSV
Export.table.toDrive({
  collection: weeklyTable,
  description: 'Mbarara_CAMS_Weekly_PM25_2021_2024',
  fileFormat: 'CSV'
});
