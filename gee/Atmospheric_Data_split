That GEE message (“An internal error has occurred”) is almost always server-side execution failure (memory/timeout/shard error) rather than “your syntax is wrong.” The quickest fix is to make the computation lighter and avoid building big intermediate collections.

Below is a more compute-efficient weekly workflow that:

does NOT create a weekly ImageCollection

computes the weekly mean only over your region (reduce early)

uses bestEffort + tileScale to reduce failures

still exports a clean weekly CSV for 2021–2024

Paste-ready GEE script (robust): Weekly PM2.5 (CAMS NRT), 2021–2024, Mbarara
/**** Robust weekly PM2.5 for Mbarara area, 2021–2024 (CAMS NRT)
 * Dataset: ECMWF/CAMS/NRT
 * Band: particulate_matter_d_less_than_25_um_surface (kg/m^3)
 * Convert to µg/m^3: * 1e9
 ****/

// -------------------------------
// 1) Region (GAUL match + fallback)
// -------------------------------
var gaul2 = ee.FeatureCollection('FAO/GAUL/2015/level2');
var ug2 = gaul2.filter(ee.Filter.eq('ADM0_NAME', 'Uganda'));

var mbarCandidates = ug2.filter(ee.Filter.stringContains('ADM2_NAME', 'Mbar'));
print('GAUL ADM2 candidates containing "Mbar":', mbarCandidates.aggregate_array('ADM2_NAME'));
print('Candidate feature count:', mbarCandidates.size());

var fallback = ee.Geometry.Point([30.65, -0.61]).buffer(20000);
var region = ee.Geometry(ee.Algorithms.If(mbarCandidates.size().gt(0),
                                         ee.FeatureCollection(mbarCandidates).geometry(),
                                         fallback));

Map.centerObject(region, 10);
Map.addLayer(region, {color: 'yellow'}, 'Mbarara area (GAUL or fallback)');

// -------------------------------
// 2) Load CAMS daily PM2.5 (one field/day)
// -------------------------------
var start = ee.Date('2021-01-01');
var end   = ee.Date('2025-01-01'); // end of 2024

var camsDaily = ee.ImageCollection('ECMWF/CAMS/NRT')
  .filterDate(start, end)
  .filter('model_initialization_hour == 0')
  .filter('model_forecast_hour == 0')
  .select('particulate_matter_d_less_than_25_um_surface')
  .map(function(img) {
    // kg/m^3 -> µg/m^3
    return img.multiply(1e9).rename('pm25_ugm3')
      .copyProperties(img, ['system:time_start']);
  });

print('Daily CAMS images:', camsDaily.size());

// Optional quick sanity map (cheap)
Map.addLayer(camsDaily.mean().clip(region), {min: 0, max: 100}, 'Mean PM2.5 (µg/m³)');

// -------------------------------
// 3) Weekly feature table (reduce early; no weekly image collection)
// -------------------------------
var nWeeks = end.difference(start, 'week').floor();
var weekIdx = ee.List.sequence(0, nWeeks.subtract(1));

var weeklyTS = ee.FeatureCollection(
  weekIdx.map(function(w) {
    w = ee.Number(w);
    var wkStart = start.advance(w, 'week');
    var wkEnd = wkStart.advance(1, 'week');

    // Weekly mean image (only used transiently)
    var wkMeanImg = camsDaily.filterDate(wkStart, wkEnd).mean();

    // Reduce over region
    var stats = wkMeanImg.reduceRegion({
      reducer: ee.Reducer.mean(),
      geometry: region,
      scale: 45000,       // CAMS is ~44km
      bestEffort: true,   // helps avoid internal failures
      tileScale: 4,       // helps with memory
      maxPixels: 1e13
    });

    return ee.Feature(null, {
      week_start: wkStart.format('YYYY-MM-dd'),
      week_end: wkEnd.advance(-1, 'day').format('YYYY-MM-dd'),
      pm25_ugm3: stats.get('pm25_ugm3')
    });
  })
).filter(ee.Filter.notNull(['pm25_ugm3']));

print('Weekly TS rows:', weeklyTS.size());
print('Weekly TS preview:', weeklyTS.limit(10));

// Chart
var chart = ui.Chart.feature.byFeature(weeklyTS, 'week_start', 'pm25_ugm3')
